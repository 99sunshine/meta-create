# MetaCreate 环境变量模板
# 复制此文件为 .env.local 并填入真实值
# 所有 NEXT_PUBLIC_ 前缀的变量会暴露到浏览器端，请勿存放私密密钥

# ── Supabase ──────────────────────────────────────────────
# 在 Supabase Dashboard → Project Settings → API 中获取
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_DEFAULT_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ── 站点 URL ───────────────────────────────────────────────
# 本地开发填 http://localhost:3000
# 生产环境填部署域名（需与 Supabase Auth → URL Configuration 中的 Site URL 一致）
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# ── AI 功能（阶段七使用）──────────────────────────────────
# 仅服务端使用，不加 NEXT_PUBLIC_ 前缀
# OPENAI_API_KEY=sk-...
